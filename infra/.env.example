# AWS CDK Infrastructure Configuration for Kiro Quest
# Copy this file to .env and fill in your values.

# AWS Account ID (required for CDK deployment)
AWS_ACCOUNT_ID=123456789012

# AWS Region for the main stack (default: us-east-1)
# Note: ACM certificates for CloudFront must be in us-east-1
AWS_REGION=us-east-1

# Domain name for the application (optional - skip to use CloudFront default URL)
# Example: kiro-quest.yourdomain.com
DOMAIN_NAME=

# Route 53 hosted zone name (required if DOMAIN_NAME is set)
# This must be an existing hosted zone in your AWS account
# Example: yourdomain.com
HOSTED_ZONE_NAME=
