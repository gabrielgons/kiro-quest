{
  "name": "kiro-quest-infra",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:frontend": "cdk deploy KiroQuestFrontendStack --require-approval never",
    "deploy:dns": "cdk deploy KiroQuestDnsStack --require-approval never",
    "sync": "node scripts/sync-to-s3.mjs"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.174.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "aws-cdk": "^2.174.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  }
}
