# Kiro Quest - Variaveis de Ambiente
#
# Copie este arquivo para .env.local (dev) ou .env.production.local (build de producao).
# Arquivos .env*.local sao ignorados pelo git.
#
# Para rodar sem autenticacao/backend, deixe os valores em branco.
# A aplicacao funciona normalmente sem backend (modo localStorage).

# URL da API Gateway (backend serverless)
# Exemplo: https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
VITE_API_URL=

# Amazon Cognito - Autenticacao
# Exemplo: us-east-1_aBcDeFgHi
VITE_COGNITO_USER_POOL_ID=
# Exemplo: 1a2b3c4d5e6f7g8h9i0j
VITE_COGNITO_CLIENT_ID=
# Exemplo: https://kiro-quest.auth.us-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=

# URIs de redirecionamento OAuth
# Exemplo: https://app.seudominio.com/auth/callback
VITE_AUTH_REDIRECT_URI=
# Exemplo: https://app.seudominio.com/
VITE_AUTH_LOGOUT_URI=
